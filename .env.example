# Database Configuration
# Ensure these match the db service environment variables in docker-compose.yml if customized
DB_ENGINE=django.db.backends.postgresql
DB_NAME=indoor_monitor
DB_USER=postgres
DB_PASSWORD=change_this_password
DB_HOST=db
DB_LOCAL=localhost

# Django Settings
DJANGO_SECRET_KEY=change_this_to_a_secure_random_string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,192.168.6.11,kcbd.grupoalvs.com
DJANGO_DEFAULT_LANGUAGE_CODE=es-ar
DJANGO_TIMEZONE=America/Argentina/Mendoza

# Domain Settings
# Used for CSRF/CORS trusted origins
DOMAIN=192.168.6.11

# Sensor Configuration
# Comma-separated list of sensor names to ignore in charts/calculations
IGNORE_SENSORS=test_sensor,broken_sensor

# Logging
DJANGO_LOG_LEVEL=INFO
DJANGO_LOGURU_LEVEL=INFO

# Security (Production)
# Set to 'True' if behind HTTPS proxy (like existing kcbd server)
# For local network 192.168.6.11 without HTTPS, set to 'False'
BEHIND_SSL_PROXY=False
CSRF_COOKIE_SECURE=False
SESSION_COOKIE_SECURE=False
